<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.DepositMapper">

    <resultMap id="BaseResultMap" type="com.example.entity.finance.DepositRecord">
        <id property="id" column="id"/>
        <result property="orderId" column="order_id"/>
        <result property="orderNo" column="order_no"/>
        <result property="userId" column="user_id"/>
        <result property="userName" column="user_name"/>
        <result property="amount" column="amount"/>
        <result property="status" column="status"/>
        <result property="deductAmount" column="deduct_amount"/>
        <result property="deductReason" column="deduct_reason"/>
        <result property="deductTime" column="deduct_time"/>
        <result property="unfrozenTime" column="unfrozen_time"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <insert id="insert" parameterType="com.example.entity.finance.DepositRecord" useGeneratedKeys="true" keyProperty="id">
        insert into deposit_record (
            order_id, order_no, user_id, user_name, amount, status, create_time
        ) values (
                     #{orderId}, #{orderNo}, #{userId}, #{userName}, #{amount}, #{status}, now()
                 )
    </insert>

    <update id="update" parameterType="com.example.entity.finance.DepositRecord">
        update deposit_record
        set status = #{status},
            deduct_amount = #{deductAmount},
            deduct_reason = #{deductReason},
            deduct_time = #{deductTime},
            unfrozen_time = #{unfrozenTime}
        where id = #{id}
    </update>

    <select id="selectById" resultMap="BaseResultMap">
        select * from deposit_record where id = #{id}
    </select>

    <select id="selectByOrderId" resultMap="BaseResultMap">
        select * from deposit_record where order_id = #{orderId}
    </select>

    <select id="selectPage" resultMap="BaseResultMap">
        select * from deposit_record
        <where>
            <if test="keyword != null and keyword != ''">
                and (user_name like concat('%', #{keyword}, '%')
                or order_no like concat('%', #{keyword}, '%'))
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
            <if test="startDate != null and startDate != ''">
                and create_time >= #{startDate}
            </if>
            <if test="endDate != null and endDate != ''">
                and create_time &lt;= #{endDate}
            </if>
        </where>
        order by create_time desc
    </select>

    <!-- 冻结中的押金（状态为 frozen） -->
    <select id="getTotalFrozen" resultType="java.math.BigDecimal">
        select ifnull(sum(amount), 0) from deposit_record where status = 'frozen'
    </select>

    <!-- 已解冻的金额（实际退还用户的金额） -->
    <select id="getTotalUnfrozen" resultType="java.math.BigDecimal">
        select ifnull(
                       (select sum(amount) from deposit_record where status = 'unfrozen')
                           +
                       (select sum(amount - deduct_amount) from deposit_record where status = 'deducted')
                   , 0)
    </select>

    <!-- 已扣除的金额 -->
    <select id="getTotalDeducted" resultType="java.math.BigDecimal">
        select ifnull(sum(deduct_amount), 0) from deposit_record where status = 'deducted'
    </select>

</mapper>