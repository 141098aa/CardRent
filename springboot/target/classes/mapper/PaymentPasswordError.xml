<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.PaymentPasswordErrorMapper">

    <resultMap id="BaseResultMap" type="com.example.entity.finance.PaymentPasswordError">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="errorCount" column="error_count"/>
        <result property="totalErrorCount" column="total_error_count"/>
        <result property="firstErrorTime" column="first_error_time"/>
        <result property="lockStartTime" column="lock_start_time"/>
        <result property="lockEndTime" column="lock_end_time"/>
        <result property="lockType" column="lock_type"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <!-- 根据用户ID查询错误记录 -->
    <select id="selectByUserId" resultMap="BaseResultMap">
        select * from payment_password_error
        where user_id = #{userId}
    </select>

    <!-- 插入错误记录 -->
    <insert id="insert" parameterType="com.example.entity.finance.PaymentPasswordError" useGeneratedKeys="true" keyProperty="id">
        insert into payment_password_error (
            user_id, error_count, total_error_count, first_error_time,
            lock_start_time, lock_end_time, lock_type, create_time
        ) values (
                     #{userId}, #{errorCount}, #{totalErrorCount}, #{firstErrorTime},
                     #{lockStartTime}, #{lockEndTime}, #{lockType}, now()
                 )
    </insert>

    <!-- 更新错误记录 -->
    <update id="update" parameterType="com.example.entity.finance.PaymentPasswordError">
        update payment_password_error
        set error_count = #{errorCount},
            total_error_count = #{totalErrorCount},
            first_error_time = #{firstErrorTime},
            lock_start_time = #{lockStartTime},
            lock_end_time = #{lockEndTime},
            lock_type = #{lockType},
            update_time = now()
        where id = #{id}
    </update>

    <!-- 删除用户的错误记录（密码重置成功时调用） -->
    <delete id="deleteByUserId">
        delete from payment_password_error
        where user_id = #{userId}
    </delete>

    <!-- 查询所有锁定的记录（用于定时任务清理过期锁定） -->
    <select id="selectAllLocked" resultMap="BaseResultMap">
        select * from payment_password_error
        where lock_end_time is not null
          and lock_end_time > now()
    </select>

    <!-- 清理过期的锁定记录（定时任务调用） -->
    <delete id="deleteExpiredLocks">
        delete from payment_password_error
        where lock_end_time is not null
          and lock_end_time &lt; now()
    </delete>

</mapper>